# Настройки администратора
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Секретный ключ для Flask (используется для сессий и flash)
SECRET_KEY=your-random-string-here

# Настройки базы данных (опционально)
# Переименовано для соответствия проекту
DATABASE_PATH=test_database.db

# Режим отладки (True для разработки, False для продакшена)
FLASK_DEBUG=True